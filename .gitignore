.terraform/
# =========================
# Terraform
# =========================

# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Ignore plan files
*.tfplan
*.plan

# Ignore lock file (optional)
# Remove this line if you WANT to track provider versions
.terraform.lock.hcl

# Ignore sensitive files
*.pem
*.key

# Ignore IDE/editor files
.vscode/
.idea/

# Ignore OS files
.DS_Store
Thumbs.db